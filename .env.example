PORT=4317
DATABASE_PATH=./data/upstream-console.sqlite

# Generate a long random value for production.
APP_SECRET=change-me-to-a-long-random-secret
SESSION_SECRET=change-me-to-another-long-random-secret
ADMIN_PASSWORD=

# Background upstream state sync. Setting false is a hard disable that the UI cannot override.
# Tick values are runtime defaults until Settings is saved in the console.
SYNC_SCHEDULER_ENABLED=true
SYNC_SCHEDULER_TICK_SECONDS=30

# Key connectivity checks. Setting false is a hard disable that the UI cannot override.
# Probes make real model requests and may have a small non-zero cost.
KEY_CHECK_SCHEDULER_ENABLED=true
KEY_CHECK_SCHEDULER_TICK_SECONDS=30
KEY_CHECK_CONCURRENCY=3
KEY_CHECK_TIMEOUT_MS=15000

# PushPlus WeChat notifications.
PUSHPLUS_TOKEN=
PUSHPLUS_BASE_URL=https://www.pushplus.plus/send
PUSHPLUS_TIMEOUT_MS=10000
ALERT_FAILURE_THRESHOLD=3
ALERT_RECOVERY_THRESHOLD=2
MAX_KEY_CHECK_LOGS=10000
MAX_SYNC_LOGS=500
MAX_RATE_SNAPSHOTS=2000

# Online updates require a clean Git checkout and a supervisor with automatic restart enabled.
SELF_UPDATE_ENABLED=false
SELF_UPDATE_REMOTE=origin
SELF_UPDATE_BRANCH=main
# UPDATE_BACKUP_DIR=/var/backups/sub2api-upstream-console

# Optional: seed a single upstream on startup for local testing.
SEED_UPSTREAM_NAME=Stone API
SEED_UPSTREAM_BASE_URL=https://www.shitoutk.com
SEED_UPSTREAM_EMAIL=
SEED_UPSTREAM_PASSWORD=

